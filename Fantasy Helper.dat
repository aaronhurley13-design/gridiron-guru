com/notebooks/data_table.ipynb>data table notebook</a>'\n","          + ' to learn more about interactive tables.';\n","        element.innerHTML = '';\n","        dataTable['output_type'] = 'display_data';\n","        await google.colab.output.renderOutput(dataTable, element);\n","        const docLink = document.createElement('div');\n","        docLink.innerHTML = docLinkHtml;\n","        element.appendChild(docLink);\n","      }\n","    </script>\n","  </div>\n","\n","\n","  <div id=\"id_07f06b5c-75fe-45a0-9b71-b8368241300a\">\n","    <style>\n","      .colab-df-generate {\n","        background-color: #E8F0FE;\n","        border: none;\n","        border-radius: 50%;\n","        cursor: pointer;\n","        display: none;\n","        fill: #1967D2;\n","        height: 32px;\n","        padding: 0 0 0 0;\n","        width: 32px;\n","      }\n","\n","      .colab-df-generate:hover {\n","        background-color: #E2EBFA;\n","        box-shadow: 0px 1px 2px rgba(60, 64, 67, 0.3), 0px 1px 3px 1px rgba(60, 64, 67, 0.15);\n","        fill: #174EA6;\n","      }\n","\n","      [theme=dark] .colab-df-generate {\n","        background-color: #3B4455;\n","        fill: #D2E3FC;\n","      }\n","\n","      [theme=dark] .colab-df-generate:hover {\n","        background-color: #434B5C;\n","        box-shadow: 0px 1px 3px 1px rgba(0, 0, 0, 0.15);\n","        filter: drop-shadow(0px 1px 2px rgba(0, 0, 0, 0.3));\n","        fill: #FFFFFF;\n","      }\n","    </style>\n","    <button class=\"colab-df-generate\" onclick=\"generateWithVariable('top_rbs')\"\n","            title=\"Generate code using this dataframe.\"\n","            style=\"display:none;\">\n","\n","  <svg xmlns=\"http://www.w3.org/2000/svg\" height=\"24px\"viewBox=\"0 0 24 24\"\n","       width=\"24px\">\n","    <path d=\"M7,19H8.4L18.45,9,17,7.55,7,17.6ZM5,21V16.75L18.45,3.32a2,2,0,0,1,2.83,0l1.4,1.43a1.91,1.91,0,0,1,.58,1.4,1.91,1.91,0,0,1-.58,1.4L9.25,21ZM18.45,9,17,7.55Zm-12,3A5.31,5.31,0,0,0,4.9,8.1,5.31,5.31,0,0,0,1,6.5,5.31,5.31,0,0,0,4.9,4.9,5.31,5.31,0,0,0,6.5,1,5.31,5.31,0,0,0,8.1,4.9,5.31,5.31,0,0,0,12,6.5,5.46,5.46,0,0,0,6.5,12Z\"/>\n","  </svg>\n","    </button>\n","    <script>\n","      (() => {\n","      const buttonEl =\n","        document.querySelector('#id_07f06b5c-75fe-45a0-9b71-b8368241300a button.colab-df-generate');\n","      buttonEl.style.display =\n","        google.colab.kernel.accessAllowed ? 'block' : 'none';\n","\n","      buttonEl.onclick = () => {\n","        google.colab.notebook.generateWithVariable('top_rbs');\n","      }\n","      })();\n","    </script>\n","  </div>\n","\n","    </div>\n","  </div>\n"],"application/vnd.google.colaboratory.intrinsic+json":{"type":"dataframe","variable_name":"top_rbs","summary":"{\n  \"name\": \"top_rbs\",\n  \"rows\": 20,\n  \"fields\": [\n    {\n      \"column\": \"player_display_name\",\n      \"properties\": {\n        \"dtype\": \"string\",\n        \"num_unique_values\": 20,\n        \"samples\": [\n          \"Christian McCaffrey\",\n          \"Rico Dowdle\",\n          \"D'Andre Swift\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"team\",\n      \"properties\": {\n        \"dtype\": \"string\",\n        \"num_unique_values\": 19,\n        \"samples\": [\n          \"SF\",\n          \"NE\",\n          \"NYJ\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"receiving_yards\",\n      \"properties\": {\n        \"dtype\": \"int32\",\n        \"num_unique_values\": 19,\n        \"samples\": [\n          1029,\n          471,\n          350\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"receiving_tds\",\n      \"properties\": {\n        \"dtype\": \"int32\",\n        \"num_unique_values\": 8,\n        \"samples\": [\n          4,\n          2,\n          9\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"receptions\",\n      \"properties\": {\n        \"dtype\": \"int32\",\n        \"num_unique_values\": 13,\n        \"samples\": [\n          41,\n          36,\n          113\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"}},"metadata":{},"execution_count":3}]},{"cell_type":"code","source":["# ==========================================\n","# 1. THE MASTER CONFIGURATION\n","# ==========================================\n","league_config = {\n","    \"name\": \"My Yahoo League\",\n","    \"teams\": 10,\n","\n","    # --- OFFENSE ---\n","    \"scoring\": {\n","        \"ppr\": 1.0,\n","        \"pass_yd\": 0.04,\n","        \"pass_td\": 4,\n","        \"interception\": -1,\n","        \"rush_yd\": 0.1,\n","        \"rush_td\": 6,\n","        \"rec_yd\": 0.1,\n","        \"rec_td\": 6,\n","        \"fumble_lost\": -2,\n","        \"pass_300_bonus\": 3,\n","        \"rush_100_bonus\": 3,\n","        \"rec_100_bonus\": 3\n","    },\n","\n","    # --- DEFENSE ---\n","    \"defense_scoring\": {\n","        \"pa_brackets\": [\n","            (0, 0, 10),\n","            (1, 6, 7),\n","            (7, 13, 4),\n","            (14, 20, 1),\n","            (21, 27, 0),\n","            (28, 34, -1),\n","            (35, 999, -4),\n","        ],\n","        \"sack\": 1,\n","        \"def_pat_return\": 1,\n","        \"interception\": 2,\n","        \"fumble_recovery\": 2,\n","        \"safety\": 2,\n","        \"blocked_kick\": 2,\n","        \"fourth_down_stop\": 2,\n","        \"three_and_out\": 2,\n","        \"yards_allowed_500_penalty\": -50\n","    },\n","\n","    # --- KICKERS ---\n","    \"kicker_scoring\": {\n","        \"fg_brackets\": [\n","            (0, 19, 3),\n","            (20, 29, 3),\n","            (30, 39, 3),\n","            (40, 49, 4),\n","            (50, 110, 6),\n","        ],\n","        \"xp\": 1,\n","    }\n","}\n","\n","# ==========================================\n","# 2. THE SCORING FUNCTIONS\n","# ==========================================\n","\n","def score_offensive_player(stats_row, config):\n","    scoring = config[\"scoring\"]\n","    points = 0.0\n","\n","    # Base yardage\n","    pass_yds = stats_row.get(\"pass_yd\", 0)\n","    rush_yds = stats_row.get(\"rush_yd\", 0)\n","    rec_yds = stats_row.get(\"rec_yd\", 0)\n","\n","    # Base points\n","    points += pass_yds * scoring[\"pass_yd\"]\n","    points += stats_row.get(\"pass_td\", 0) * scoring[\"pass_td\"]\n","    points += stats_row.get(\"interception\", 0) * scoring[\"interception\"]\n","\n","    points += rush_yds * scoring[\"rush_yd\"]\n","    points += stats_row.get(\"rush_td\", 0) * scoring[\"rush_td\"]\n","\n","    points += stats_row.get(\"receptions\", 0) * scoring[\"ppr\"]\n","    points += rec_yds * scoring[\"rec_yd\"]\n","    points += stats_row.get(\"rec_td\", 0) * scoring[\"rec_td\"]\n","\n","    points += stats_row.get(\"fumble_lost\", 0) * scoring[\"fumble_lost\"]\n","\n","    # Bonuses\n","    if pass_yds >= 300:\n","        points += scoring.get(\"pass_300_bonus\", 0)\n","    if rush_yds >= 100:\n","        points += scoring.get(\"rush_100_bonus\", 0)\n","    if rec_yds >= 100:\n","        points += scoring.get(\"rec_100_bonus\", 0)\n","\n","    return points\n","\n","def score_defense(stats_row, config):\n","    def_config = config[\"defense_scoring\"]\n","    points = 0.0\n","\n","    # Points Allowed\n","    pa = stats_row.get(\"points_allowed\", 0)\n","    for lower, upper, bracket_points in def_config[\"pa_brackets\"]:\n","        if lower <= pa <= upper:\n","            points += bracket_points\n","            break\n","\n","    # Stats\n","    points += stats_row.get(\"sack\", 0) * def_config.get(\"sack\", 0)\n","    points += stats_row.get(\"def_pat_return\", 0) * def_config.get(\"def_pat_return\", 0)\n","    points += stats_row.get(\"interception\", 0) * def_config.get(\"interception\", 0)\n","    points += stats_row.get(\"fumble_recovery\", 0) * def_config.get(\"fumble_recovery\", 0)\n","    points += stats_row.get(\"safety\", 0) * def_config.get(\"safety\", 0)\n","    points += stats_row.get(\"blocked_kick\", 0) * def_config.get(\"blocked_kick\", 0)\n","    points += stats_row.get(\"fourth_down_stop\", 0) * def_config.get(\"fourth_down_stop\", 0)\n","    points += stats_row.get(\"three_and_out\", 0) * def_config.get(\"three_and_out\", 0)\n","\n","    # Yards Penalty\n","    yards_allowed = stats_row.get(\"yards_allowed\", 0)\n","    if yards_allowed > 500:\n","        points += def_config.get(\"yards_allowed_500_penalty\", 0)\n","\n","    return points\n","\n","def score_kicker(stats_row, config):\n","    kicker_config = config[\"kicker_scoring\"]\n","    points = 0.0\n","\n","    # Extra Points\n","    points += stats_row.get(\"xp_made\", 0) * kicker_config.get(\"xp\", 1)\n","\n","    # Field Goals\n","    fg_distances = stats_row.get(\"fg_made_distances\", [])\n","    for distance in fg_distances:\n","        for lower, upper, bracket_points in kicker_config[\"fg_brackets\"]:\n","            if lower <= distance <= upper:\n","                points += bracket_points\n","                break\n","\n","    return points"],"metadata":{"id":"gfVW5oMQnpCb"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ==========================================\n","# CORE DRAFT ENGINE FUNCTIONS\n","# ==========================================\n","\n","# 1. DETERMINE WHOSE TURN IT IS\n","def whose_pick(pick_num, num_teams):\n","    round_num = ((pick_num - 1) // num_teams) + 1\n","    position_in_round = ((pick_num - 1) % num_teams) + 1\n","    if round_num % 2 == 1:\n","        return position_in_round\n","    else:\n","        return num_teams - position_in_round + 1\n","\n","\n","# 2. RECORD A PICK\n","def record_pick(player_name, team_id, position):\n","    \"\"\"Adds a drafted player and their position to the draft board.\"\"\"\n","    pick_num = Draft_state[\"current_pick\"]\n","    Draft_state[\"picks\"].append((pick_num, team_id, player_name, position.upper()))\n","    Draft_state[\"current_pick\"] += 1\n","\n","\n","# 3. GET AVAILABLE PLAYERS\n","def available_players(all_players_df, draft_state_dict):\n","    \"\"\"Returns a filtered DataFrame containing only undrafted players.\"\"\"\n","    drafted_names = [pick[2] for pick in draft_state_dict[\"picks\"]]\n","    available_df = all_players_df[~all_players_df[\"player_name\"].isin(drafted_names)]\n","    return available_df\n","\n","\n","# 4. CALCULATE TEAM NEEDS\n","def team_needs(team_id, draft_state_dict):\n","    \"\"\"Returns the roster slots that a specific team still needs to fill.\"\"\"\n","    needs = draft_state_dict[\"roster_template\"].copy()\n","    team_picks = [pick for pick in draft_state_dict[\"picks\"] if pick[1] == team_id]\n","\n","    for _, _, _, pos in team_picks:\n","        if pos in [\"QB\", \"K\", \"DEF\"]:\n","            if needs[pos] > 0: needs[pos] -= 1\n","            else: needs[\"BENCH\"] -= 1\n","        elif pos in [\"RB\", \"WR\", \"TE\"]:\n","            if needs[pos] > 0: needs[pos] -= 1\n","            elif needs[\"FLEX\"] > 0: needs[\"FLEX\"] -= 1\n","            else: needs[\"BENCH\"] -= 1\n","        else:\n","            needs[\"BENCH\"] -= 1\n","    return {slot: count for slot, count in needs.items() if count > 0}\n","\n","\n","# 5. BUILD THE PROMPT FOR GEMINI\n","def build_prompt(draft_state, top_available, league_config):\n","    \"\"\"Generates a text prompt to ask an LLM for draft advice.\"\"\"\n","    my_team = draft_state[\"my_team_id\"]\n","    current_pick = draft_state[\"current_pick\"]\n","    my_picks = [pick for pick in draft_state[\"picks\"] if pick[1] == my_team]\n","\n","    if my_picks:\n","        roster_text = \"\\n\".join([f\"- {pick[2]} ({pick[3]})\" for pick in my_picks])\n","    else:\n","        roster_text = \"No players drafted yet.\"\n","\n","    top_15_df = top_available.head(15)\n","    available_text = top_15_df.to_string(index=False)\n","\n","    prompt = f\"\"\"You are an expert fantasy football draft consultant. I need you to recommend my next draft pick.\n","\n","### League Scoring Rules\n","- PPR: {league_config['scoring'].get('ppr', 0)}\n","- Pass TD: {league_config['scoring'].get('pass_td', 4)} points\n","- Rush/Rec TD: {league_config['scoring'].get('rush_td', 6)} points\n","- Pass Yards: {league_config['scoring'].get('pass_yd', 0.04)} per yard\n","- Rush/Rec Yards: {league_config['scoring'].get('rush_yd', 0.1)} per yard\n","\n","### Current Draft Situation\n","- Current Overall Pick: {current_pick}\n","- My Team: Team {my_team}\n","\n","### My Current Roster\n","{roster_text}\n","\n","### Top Available Players\n","{available_text}\n","\n","Based on my current roster needs, the value of the available players, and the league scoring rules, who is the absolute best player I should draft with this pick, and why?\n","\"\"\"\n","    return prompt.strip()\n","\n","print(\"All functions successfully loaded and ready to go!\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"id":"mc4lX3LkIFoz","executionInfo":{"status":"ok","timestamp":1780685945582,"user_tz":300,"elapsed":11,"user":{"displayName":"Aaron Hurley","userId":"05835087564759951446"}},"outputId":"4b44704f-2779-41bf-d28a-6aeb6dbea925"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["All functions successfully loaded and ready to go!\n"]}]},{"cell_type":"code","source":["import pandas as pd\n","\n","# 1. COMPLETELY INITIALIZE AND RESET THE DRAFT STATE\n","Draft_state = {\n","    \"my_team_id\": 5,      # which team you are (1-indexed)\n","    \"num_teams\": 12,\n","    \"current_pick\": 1,    # overall pick number\n","    \"picks\": [],          # list of (overall_pick, team_id, player_name, position)\n","    \"roster_template\": {\n","        \"QB\": 1, \"RB\": 2, \"WR\": 2, \"TE\": 1,\n","        \"FLEX\": 1, \"K\": 1, \"DEF\": 1, \"BENCH\": 6\n","    }\n","}\n","\n","# 2. EXPAND THE PLAYER POOL (50 Players)\n","mock_players = [\n","    {\"player_name\": \"Bijan Robinson\", \"position\": \"RB\"},\n","    {\"player_name\": \"Ja'Marr Chase\", \"position\": \"WR\"},\n","    {\"player_name\": \"Jahmyr Gibbs\", \"position\": \"RB\"},\n","    {\"player_name\": \"Christian McCaffrey\", \"position\": \"RB\"},\n","    {\"player_name\": \"Puka Nacua\", \"position\": \"WR\"},\n","    {\"player_name\": \"Jaxon Smith-Njigba\", \"position\": \"WR\"},\n","    {\"player_name\": \"CeeDee Lamb\", \"position\": \"WR\"},\n","    {\"player_name\": \"Jonathan Taylor\", \"position\": \"RB\"},\n","    {\"player_name\": \"Amon-Ra St. Brown\", \"position\": \"WR\"},\n","    {\"player_name\": \"Justin Jefferson\", \"position\": \"WR\"},\n","    {\"player_name\": \"James Cook III\", \"position\": \"RB\"},\n","    {\"player_name\": \"Drake London\", \"position\": \"WR\"},\n","    {\"player_name\": \"Saquon Barkley\", \"position\": \"RB\"},\n","    {\"player_name\": \"Ashton Jeanty\", \"position\": \"RB\"},\n","    {\"player_name\": \"Kenneth Walker III\", \"position\": \"RB\"},\n","    {\"player_name\": \"Chase Brown\", \"position\": \"RB\"},\n","    {\"player_name\": \"Omarion Hampton\", \"position\": \"RB\"},\n","    {\"player_name\": \"Brock Bowers\", \"position\": \"TE\"},\n","    {\"player_name\": \"George Pickens\", \"position\": \"WR\"},\n","    {\"player_name\": \"Nico Collins\", \"position\": \"WR\"},\n","    {\"player_name\": \"A.J. Brown\", \"position\": \"WR\"},\n","    {\"player_name\": \"De'Von Achane\", \"position\": \"RB\"},\n","    {\"player_name\": \"Rashee Rice\", \"position\": \"WR\"},\n","    {\"player_name\": \"Sam LaPorta\", \"position\": \"TE\"},\n","    {\"player_name\": \"Travis Kelce\", \"position\": \"TE\"},\n","    {\"player_name\": \"Josh Allen\", \"position\": \"QB\"},\n","    {\"player_name\": \"Lamar Jackson\", \"position\": \"QB\"},\n","    {\"player_name\": \"Jalen Hurts\", \"position\": \"QB\"},\n","    {\"player_name\": \"Derrick Henry\", \"position\": \"RB\"},\n","    {\"player_name\": \"Deebo Samuel Sr.\", \"position\": \"WR\"},\n","    {\"player_name\": \"Mike Evans\", \"position\": \"WR\"},\n","    {\"player_name\": \"Patrick Mahomes\", \"position\": \"QB\"},\n","    {\"player_name\": \"Tyreek Hill\", \"position\": \"WR\"},\n","    {\"player_name\": \"Breece Hall\", \"position\": \"RB\"},\n","    {\"player_name\": \"Garrett Wilson\", \"position\": \"WR\"},\n","    {\"player_name\": \"Kyren Williams\", \"position\": \"RB\"},\n","    {\"player_name\": \"Marvin Harrison Jr.\", \"position\": \"WR\"},\n","    {\"player_name\": \"Davante Adams\", \"position\": \"WR\"},\n","    {\"player_name\": \"Chris Olave\", \"position\": \"WR\"},\n","    {\"player_name\": \"Isiah Pacheco\", \"position\": \"RB\"},\n","    {\"player_name\": \"Travis Etienne Jr.\", \"position\": \"RB\"},\n","    {\"player_name\": \"Trey McBride\", \"position\": \"TE\"},\n","    {\"player_name\": \"Dalton Kincaid\", \"position\": \"TE\"},\n","    {\"player_name\": \"Colston Loveland\", \"position\": \"TE\"},\n","    {\"player_name\": \"Tucker Kraft\", \"position\": \"TE\"},\n","    {\"player_name\": \"Jayden Daniels\", \"position\": \"QB\"},\n","    {\"player_name\": \"Joe Burrow\", \"position\": \"QB\"},\n","    {\"player_name\": \"Bo Nix\", \"position\": \"QB\"},\n","    {\"player_name\": \"Caleb Williams\", \"position\": \"QB\"},\n","    {\"player_name\": \"Drake Maye\", \"position\": \"QB\"}\n","]\n","\n","all_players_df = pd.DataFrame(mock_players)\n","print(f\"Success! Draft_state is initialized at Pick 1 and player pool has {len(all_players_df)} players.\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"id":"lfq6PSs7Hich","executionInfo":{"status":"ok","timestamp":1780685362817,"user_tz":300,"elapsed":15,"user":{"displayName":"Aaron Hurley","userId":"05835087564759951446"}},"outputId":"0f294fa9-52de-4b7b-d007-bb7e6a422d41"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Success! Draft_state is initialized at Pick 1 and player pool has 50 players.\n"]}]},{"cell_type":"code","source":["# ==========================================\n","# 1. THE PROMPT BUILDER\n","# ==========================================\n","def build_prompt(draft_state, top_available, league_config):\n","    \"\"\"Generates a text prompt to ask an LLM for draft advice.\"\"\"\n","\n","    # Extract context from the draft state\n","    my_team = draft_state[\"my_team_id\"]\n","    current_pick = draft_state[\"current_pick\"]\n","\n","    # Grab just the players that MY team has drafted so far\n","    my_picks = [pick for pick in draft_state[\"picks\"] if pick[1] == my_team]\n","\n","    # Format my roster into a readable list, or a default message if empty\n","    if my_picks:\n","        roster_text = \"\\n\".join([f\"- {pick[2]} ({pick[3]})\" for pick in my_picks])\n","    else:\n","        roster_text = \"No players drafted yet.\"\n","\n","    # Format the top 15 available players\n","    top_15_df = top_available.head(15)\n","    available_text = top_15_df.to_string(index=False)\n","\n","    # Build the actual string prompt using an f-string\n","    prompt = f\"\"\"You are an expert fantasy football draft consultant. I need you to recommend my next draft pick.\n","\n","### League Scoring Rules\n","- PPR: {league_config['scoring'].get('ppr', 0)}\n","- Pass TD: {league_config['scoring'].get('pass_td', 4)} points\n","- Rush/Rec TD: {league_config['scoring'].get('rush_td', 6)} points\n","- Pass Yards: {league_config['scoring'].get('pass_yd', 0.04)} per yard\n","- Rush/Rec Yards: {league_config['scoring'].get('rush_yd', 0.1)} per yard\n","\n","### Current Draft Situation\n","- Current Overall Pick: {current_pick}\n","- My Team: Team {my_team}\n","\n","### My Current Roster\n","{roster_text}\n","\n","### Top Available Players\n","{available_text}\n","\n","Based on my current roster needs, the value of the available players, and the league scoring rules, who is the absolute best player I should draft with this pick, and why?\n","\"\"\"\n","    return prompt.strip()\n","\n","\n","# ==========================================\n","# 2. GENERATE THE TEXT TO COPY/PASTE\n","# ==========================================\n","# Get the top available players (using the function built earlier)\n","remaining_players_df = available_players(all_players_df, Draft_state)\n","\n","# Build the giant text prompt\n","my_prompt = build_prompt(Draft_state, remaining_players_df, league_config)\n","\n","# Print the final result so you can highlight and copy it!\n","print(\"=== HIGHLIGHT AND COPY THE TEXT BELOW ===\\n\")\n","print(my_prompt)\n","print(\"\\n=========================================\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"pZAcroaQsGf9","executionInfo":{"status":"ok","timestamp":1780686191546,"user_tz":300,"elapsed":4,"user":{"displayName":"Aaron Hurley","userId":"05835087564759951446"}},"outputId":"5091cd41-00ab-48c4-e726-e9568b00cc58","collapsed":true},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["=== HIGHLIGHT AND COPY THE TEXT BELOW ===\n","\n","You are an expert fantasy football draft consultant. I need you to recommend my next draft pick.\n","\n","### League Scoring Rules\n","- PPR: 1.0\n","- Pass TD: 4 points\n","- Rush/Rec TD: 6 points\n","- Pass Yards: 0.04 per yard\n","- Rush/Rec Yards: 0.1 per yard\n","\n","### Current Draft Situation\n","- Current Overall Pick: 1\n","- My Team: Team 5\n","\n","### My Current Roster\n","No players drafted yet.\n","\n","### Top Available Players\n","        player_name position\n","     Bijan Robinson       RB\n","      Ja'Marr Chase       WR\n","       Jahmyr Gibbs       RB\n","Christian McCaffrey       RB\n","         Puka Nacua       WR\n"," Jaxon Smith-Njigba       WR\n","        CeeDee Lamb       WR\n","    Jonathan Taylor       RB\n","  Amon-Ra St. Brown       WR\n","   Justin Jefferson       WR\n","     James Cook III       RB\n","       Drake London       WR\n","     Saquon Barkley       RB\n","      Ashton Jeanty       RB\n"," Kenneth Walker III       RB\n","\n","Based on my current roster needs, the value of the available players, and the league scoring rules, who is the absolute best player I should draft with this pick, and why?\n","\n","=========================================\n"]}]},{"cell_type":"code","source":["def build_prompt(draft_state, top_available, league_config):\n","    \"\"\"Generates a text prompt that forces Gemini to respond ONLY in a clean JSON format.\"\"\"\n","    my_team = draft_state[\"my_team_id\"]\n","    current_pick = draft_state[\"current_pick\"]\n","    my_picks = [pick for pick in draft_state[\"picks\"] if pick[1] == my_team]\n","\n","    if my_picks:\n","        roster_text = \"\\n\".join([f\"- {pick[2]} ({pick[3]})\" for pick in my_picks])\n","    else:\n","        roster_text = \"No players drafted yet.\"\n","\n","    top_15_df = top_available.head(15)\n","    available_text = top_15_df.to_string(index=False)\n","\n","    prompt = f\"\"\"You are an expert fantasy football draft consultant.\n","\n","### League Scoring Rules\n","- PPR: {league_config['scoring'].get('ppr', 0)}\n","- Pass TD: {league_config['scoring'].get('pass_td', 4)} points\n","- Rush/Rec TD: {league_config['scoring'].get('rush_td', 6)} points\n","- Pass Yards: {league_config['scoring'].get('pass_yd', 0.04)} per yard\n","- Rush/Rec Yards: {league_config['scoring'].get('rush_yd', 0.1)} per yard\n","\n","### Current Draft Situation\n","- Current Overall Pick: {current_pick}\n","- My Team: Team {my_team}\n","\n","### My Current Roster\n","{roster_text}\n","\n","### Top Available Players\n","{available_text}\n","\n","### Instructions\n","Question: Who should I pick? Consider position scarcity, my roster construction, and the custom landmines in my league's scoring.\n","\n","Respond ONLY in this JSON Format:\n","{{\n","  \"pick\": \"Player Name\",\n","  \"position\": \"Position\",\n","  \"reasoning\": \"2-3 sentences explaining the pick\"\n","}}\n","\"\"\"\n","    return prompt.strip()\n"],"metadata":{"id":"tacWZXwjKqxA"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import json\n","\n","def parse_gemini_response(response_text):\n","    cleaned_text = response_text.strip()\n","\n","    # Create the 3-backtick string without typing it sequentially\n","    three_ticks = '`' + '`' + '`'\n","\n","    if cleaned_text.startswith(three_ticks):\n","        first_newline = cleaned_text.find(\"\\n\")\n","        last_backticks = cleaned_text.rfind(three_ticks)\n","        if first_newline != -1 and last_backticks != -1 and last_backticks > first_newline:\n","            cleaned_text = cleaned_text[first_newline:last_backticks].strip()\n","\n","    try:\n","        return json.loads(cleaned_text)\n","    except json.JSONDecodeError as e:\n","        print(\"Failed to parse valid JSON. Raw text was:\")\n","        print(response_text)\n","        return None\n"],"metadata":{"id":"07JM2N_PMHz4"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# 1. Provide a clean test string (simulating Gemini's output)\n","test_reply = '{\"pick\": \"Bijan Robinson\", \"position\": \"RB\", \"reasoning\": \"Great pick.\"}'\n","\n","# 2. Run it through your newly fixed parser function\n","parsed_data = parse_gemini_response(test_reply)\n","\n","# 3. Print the final parsed result\n","print(\"Success! Your parsed dictionary looks like this:\")\n","print(parsed_data)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"nadXqEDcMcFG","executionInfo":{"status":"ok","timestamp":1780686642650,"user_tz":300,"elapsed":9,"user":{"displayName":"Aaron Hurley","userId":"05835087564759951446"}},"outputId":"31847caa-61dc-4ae6-8ea2-c7468326d47f"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Success! Your parsed dictionary looks like this:\n","{'pick': 'Bijan Robinson', 'position': 'RB', 'reasoning': 'Great pick.'}\n"]}]},{"cell_type":"code","source":["%%writefile app.py\n","import streamlit as st\n","import pandas as pd\n","import json, io, os\n","\n","st.set_page_config(page_title=\"Gridiron Guru\", page_icon=\"🏈\", layout=\"wide\")\n","\n","@st.cache_data\n","def load_initial_player_pool():\n","    csv_files = [f for f in os.listdir('.') if f.endswith('.csv')]\n","    if csv_files:\n","        try:\n","            df = pd.read_csv(csv_files[0])\n","            df.columns = df.columns.str.strip().str.lower()\n","            df.rename(columns={\"player\": \"player_name\", \"player name\": \"player_name\", \"name\": \"player_name\", \"pos\": \"position\"}, inplace=True)\n","            if \"position\" in df.columns:\n","                df['position'] = df['position'].astype(str).str.replace(r'\\d+', '', regex=True)\n","            return df\n","        except Exception: pass\n","    return pd.read_csv(io.StringIO(\"player_name,position,bye week\\nChristian McCaffrey,RB,9\\nCeeDee Lamb,WR,7\\nTyreek Hill,WR,6\\nJa'Marr Chase,WR,12\\nJustin Jefferson,WR,6\\nBijan Robinson,RB,12\\nAmon-Ra St. Brown,WR,5\\nBreece Hall,RB,12\\nA.J. Brown,WR,5\\nPuka Nacua,WR,6\\nJahmyr Gibbs,RB,5\\nJonathan Taylor,RB,14\\nGarrett Wilson,WR,12\\nSaquon Barkley,RB,5\\nKyren Williams,RB,6\"))\n","\n","def build_prompt(picks_list, my_team_id, my_team_name, current_pick, league_config, top_available_df):\n","    my_picks = [p for p in picks_list if p[\"team\"] == my_team_id]\n","    roster_text = \"\\n\".join([f\"- {p['player']} ({p['position']})\" for p in my_picks]) if my_picks else \"No players drafted yet.\"\n","    available_text = top_available_df.head(15).to_string(index=False) if not top_available_df.empty else \"No available players left.\"\n","    kicker_rules = \", \".join([f\"{row['Points']} pts for {row['Range']}\" for row in league_config['kicker']])\n","    def_rules = \", \".join([f\"{row['Points']} pts per {row['Stat']}\" for row in league_config['defense']])\n","    roster_spots = \", \".join([f\"{row['Count']} {row['Position']}\" for row in league_config['roster']])\n","    return f\"\"\"You are an expert fantasy football draft consultant.\n","### League Scoring Rules & Roster Constraints\n","- PPR: {league_config['ppr']} | Pass TD: {league_config['pass_td']} | Rush/Rec TD: {league_config['rush_td']}\n","- Kickers: {kicker_rules} | Defense: {def_rules} | Roster Setup: {roster_spots}\n","### Current Draft Situation\n","- Current Overall Pick: {current_pick} | My Team: {my_team_name}\n","### My Current Roster\n","{roster_text}\n","### Top Available Players\n","{available_text}\n","### Instructions\n","Question: Who should I pick? Consider position scarcity, roster construction, and scoring landmines. Do not recommend K or DST until the final two rounds unless strictly necessary.\n","Respond ONLY in this JSON Format:\n","{{\"pick\": \"Player Name\", \"position\": \"Position\", \"reasoning\": \"2-3 sentences explaining the pick\"}}\"\"\".strip()\n","\n","def parse_gemini_response(text):\n","    t = text.strip()\n","    if t.startswith('```'):\n","        first, last = t.find(\"\\n\"), t.rfind('```')\n","        if -1 < first < last: t = t[first:last].strip()\n","    try: return json.loads(t)\n","    except: return None\n","\n","if 'all_players' not in st.session_state: st.session_state.all_players = load_initial_player_pool()\n","if 'picks' not in st.session_state: st.session_state.picks = []\n","if 'queue' not in st.session_state: st.session_state.queue = []\n","if 'kicker_scoring' not in st.session_state: st.session_state.kicker_scoring = pd.DataFrame([{\"Range\": \"0-39 yds\", \"Points\": 3}, {\"Range\": \"40-49 yds\", \"Points\": 4}, {\"Range\": \"50+ yds\", \"Points\": 5}, {\"Range\": \"PAT\", \"Points\": 1}])\n","if 'defense_scoring' not in st.session_state: st.session_state.defense_scoring = pd.DataFrame([{\"Stat\": \"Turnover\", \"Points\": 2}, {\"Stat\": \"Sack\", \"Points\": 1}, {\"Stat\": \"Safety\", \"Points\": 2}])\n","if 'roster_spots' not in st.session_state: st.session_state.roster_spots = pd.DataFrame([{\"Position\": \"QB\", \"Count\": 1}, {\"Position\": \"RB\", \"Count\": 2}, {\"Position\": \"WR\", \"Count\": 2}, {\"Position\": \"TE\", \"Count\": 1}, {\"Position\": \"FLEX\", \"Count\": 1}, {\"Position\": \"K\", \"Count\": 1}, {\"Position\": \"DST\", \"Count\": 1}, {\"Position\": \"Bench\", \"Count\": 6}])\n","\n","if 'team_names' not in st.session_state or type(st.session_state.team_names) is not pd.DataFrame or \"ID\" not in st.session_state.team_names.columns:\n","    st.session_state.team_names = pd.DataFrame([{\"ID\": i, \"Team Name\": f\"Team {i}\"} for i in range(1, 17)])\n","\n","title_col, image_col = st.columns([2, 1])\n","with title_col: st.title(\"Gridiron Guru\")\n","with image_col: st.image(\"https://neon-factory.com/cdn/shop/products/helmet-512-American_-football_-football-club_-helmet_-safety_-soccer_-sport_eecf343f-8f31-4c95-adde-61901ee87fea_1024x1024@2x.png?v=1575240399\", width=150)\n","\n","with st.sidebar:\n","    st.header(\"⚙️ Settings & Imports\")\n","    uploaded_csv = st.file_uploader(\"Upload temporary rankings (.csv)\", type=[\"csv\"])\n","    if uploaded_csv is not None:\n","        try:\n","            temp_df = pd.read_csv(uploaded_csv)\n","            temp_df.columns = temp_df.columns.str.strip().str.lower()\n","            temp_df.rename(columns={\"player\": \"player_name\", \"player name\": \"player_name\", \"name\": \"player_name\", \"pos\": \"position\"}, inplace=True)\n","            if \"position\" in temp_df.columns: temp_df['position'] = temp_df['position'].astype(str).str.replace(r'\\d+', '', regex=True)\n","            st.session_state.all_players = temp_df\n","            st.success(\"Custom player list loaded!\")\n","        except Exception: st.error(\"Error reading CSV file.\")\n","\n","    uploaded_file = st.file_uploader(\"Load Saved Config (.json)\", type=[\"json\"])\n","    if uploaded_file is not None:\n","        try:\n","            loaded_data = json.load(uploaded_file)\n","            st.session_state.kicker_scoring = pd.DataFrame(loaded_data[\"kicker\"])\n","            st.session_state.defense_scoring = pd.DataFrame(loaded_data[\"defense\"])\n","            st.session_state.roster_spots = pd.DataFrame(loaded_data[\"roster\"])\n","            st.success(\"Config loaded!\")\n","        except Exception: st.error(\"Error reading JSON file.\")\n","\n","    teams = st.number_input(\"Number of teams\", min_value=8, max_value=16, value=12)\n","    my_team_id = st.number_input(\"My Team Number\", min_value=1, max_value=teams, value=1)\n","\n","    st.markdown(\"### 🏷️ Custom Team Names\")\n","    edited_teams = st.data_editor(st.session_state.team_names.head(teams), hide_index=True, use_container_width=True)\n","    team_name_map = dict(zip(edited_teams[\"ID\"], edited_teams[\"Team Name\"]))\n","    my_team_name = team_name_map.get(my_team_id, f\"Team {my_team_id}\")\n","\n","    draft_type = st.radio(\"Draft Type\", options=[\"Snake\", \"Linear\"], horizontal=True)\n","    st.markdown(\"### Basic Scoring\")\n","    ppr = st.slider(\"PPR value\", 0.0, 1.0, 1.0, 0.5)\n","    pass_td = st.number_input(\"Pass TD Points\", value=4)\n","    rush_td = st.number_input(\"Rush/Rec TD Points\", value=6)\n","\n","    st.markdown(\"### 🏈 Roster Size\")\n","    edited_roster = st.data_editor(st.session_state.roster_spots, num_rows=\"dynamic\", use_container_width=True)\n","    st.markdown(\"### 🦵 Kicker\")\n","    edited_kicker = st.data_editor(st.session_state.kicker_scoring, num_rows=\"dynamic\", use_container_width=True)\n","    st.markdown(\"### 🛡️ Defense\")\n","    edited_defense = st.data_editor(st.session_state.defense_scoring, num_rows=\"dynamic\", use_container_width=True)\n","\n","    league_config = {\"teams\": teams, \"ppr\": ppr, \"pass_td\": pass_td, \"rush_td\": rush_td, \"draft_type\": draft_type, \"kicker\": edited_kicker.to_dict(orient=\"records\"), \"defense\": edited_defense.to_dict(orient=\"records\"), \"roster\": edited_roster.to_dict(orient=\"records\")}\n","    st.download_button(label=\"📥 Save Config File\", data=json.dumps(league_config, indent=2), file_name=\"my_league_config.json\", mime=\"application/json\")\n","    if st.button(\"Reset Draft Board\"):\n","        st.session_state.picks, st.session_state.queue = [], []\n","        st.session_state.all_players = load_initial_player_pool()\n","        st.rerun()\n","\n","current_pick = len(st.session_state.picks) + 1\n","drafted_names = [p[\"player\"] for p in st.session_state.picks]\n","round_num = (current_pick - 1) // teams + 1\n","pick_in_round = (current_pick - 1) % teams + 1\n","auto_team_id = (teams - pick_in_round + 1) if (draft_type == \"Snake\" and round_num % 2 == 0) else pick_in_round\n","\n","st.session_state.queue = [p for p in st.session_state.queue if p not in drafted_names]\n","available_df = st.session_state.all_players[~st.session_state.all_players[\"player_name\"].isin(drafted_names)] if \"player_name\" in st.session_state.all_players.columns else pd.DataFrame()\n","\n","# ==========================================\n","# DRAFT QUEUE WITH POSITION FILTER 🎯\n","# ==========================================\n","st.markdown(\"---\")\n","st.header(\"🎯 Draft Queue\")\n","if not available_df.empty:\n","    queue_filter = st.radio(\"Filter Queue by Position:\", [\"ALL\", \"QB\", \"RB\", \"WR\", \"TE\", \"K\", \"DST\"], horizontal=True)\n","\n","    if queue_filter == \"ALL\":\n","        filtered_names = available_df[\"player_name\"].tolist()\n","    else:\n","        filtered_names = available_df[available_df['position'].str.contains(queue_filter, case=False, na=False)][\"player_name\"].tolist()\n","\n","    # 🚨 THE FIX: Scrub out any NaN or blank values before sorting\n","    safe_options = list(set(filtered_names + st.session_state.queue))\n","    safe_options = [str(x) for x in safe_options if pd.notna(x) and str(x).strip() != \"\"]\n","    safe_options.sort()\n","\n","    st.session_state.queue = st.multiselect(\"Search and pin players to your Watchlist:\", options=safe_options, default=st.session_state.queue)\n","\n","    if st.session_state.queue:\n","        cols = st.columns(min(len(st.session_state.queue), 4))\n","        for i, q_player in enumerate(st.session_state.queue):\n","            with cols[i % 4]: st.info(f\"📌 {q_player}\")\n","st.markdown(\"---\")\n","\n","col1, col2 = st.columns(2)\n","with col1:\n","    st.header(\"📋 Record a Pick\")\n","    if not available_df.empty:\n","        # Scrub the main dropdown list as well just to be totally safe!\n","        all_available_names = [str(x) for x in available_df[\"player_name\"].tolist() if pd.notna(x) and str(x).strip() != \"\"]\n","        dropdown_options = st.session_state.queue + [p for p in all_available_names if p not in st.session_state.queue]\n","\n","        player = st.selectbox(\"Player drafted\", options=dropdown_options)\n","        team_options = [team_name_map[i] for i in range(1, teams + 1)]\n","        safe_index = min(max(0, int(auto_team_id) - 1), max(0, len(team_options) - 1))\n","\n","        selected_team_name = st.selectbox(f\"Drafting Team (Round {round_num})\", options=team_options, index=safe_index, key=f\"team_input_{current_pick}\")\n","        team_id = team_options.index(selected_team_name) + 1\n","\n","        matched = st.session_state.all_players[st.session_state.all_players[\"player_name\"] == player]\n","        detected_pos = matched[\"position\"].values[0] if not matched.empty else \"WR\"\n","        detected_bye = matched[\"bye week\"].values[0] if \"bye week\" in st.session_state.all_players.columns and not matched.empty else None\n","\n","        if team_id == my_team_id and pd.notna(detected_bye):\n","            my_current_roster = [p for p in st.session_state.picks if p[\"team\"] == my_team_id]\n","            if [p[\"player\"] for p in my_current_roster if p[\"position\"] == detected_pos and p.get(\"bye_week\") == detected_bye]:\n","                st.error(f\"🚨 **Bye-Week Collision:** You already drafted a **{detected_pos}** that has a Week {int(detected_bye)} bye!\")\n","\n","        btn_col1, btn_col2 = st.columns(2)\n","        with btn_col1:\n","            if st.button(\"Add Pick 🏈\"):\n","                st.session_state.picks.append({\"pick\": current_pick, \"team_name\": selected_team_name, \"team\": team_id, \"player\": player, \"position\": detected_pos, \"bye_week\": detected_bye})\n","                st.rerun()\n","        with btn_col2:\n","            if st.button(\"Undo Last Pick ⏪\"):\n","                if st.session_state.picks: st.session_state.picks.pop(); st.rerun()\n","                else: st.warning(\"No picks to undo!\")\n","    else: st.write(\"No remaining players in the database pool.\")\n","\n","with col2:\n","    st.header(\"📊 Draft Board\")\n","    if st.session_state.picks:\n","        display_df = pd.DataFrame(st.session_state.picks)\n","        if \"bye_week\" in display_df.columns: display_df = display_df.drop(columns=[\"bye_week\", \"team\"])\n","        display_df = display_df.rename(columns={\"pick\": \"Pick\", \"team_name\": \"Team\", \"player\": \"Player\", \"position\": \"Position\"})\n","        st.dataframe(display_df, use_container_width=True)\n","    else: st.info(\"No picks yet\")\n","\n","st.markdown(\"---\")\n","st.header(\"📈 My Roster Progress\")\n","my_roster_picks = [p for p in st.session_state.picks if p[\"team\"] == my_team_id]\n","pos_counts = {}\n","for p in my_roster_picks: pos_counts[p[\"position\"]] = pos_counts.get(p[\"position\"], 0) + 1\n","\n","reqs = {row[\"Position\"].upper(): int(row[\"Count\"]) for idx, row in st.session_state.roster_spots.iterrows()}\n","core_positions = [\"QB\", \"RB\", \"WR\", \"TE\", \"K\", \"DST\"]\n","flex_eligible = [\"RB\", \"WR\", \"TE\"]\n","flex_overflow, bench_overflow = 0, 0\n","\n","for pos in core_positions:\n","    drafted, req = pos_counts.get(pos, 0), reqs.get(pos, 0)\n","    overflow = drafted - req\n","    if overflow > 0:\n","        if pos in flex_eligible: flex_overflow += overflow\n","        else: bench_overflow += overflow\n","\n","req_flex = reqs.get(\"FLEX\", 0)\n","flex_filled = min(flex_overflow, req_flex)\n","bench_overflow += (flex_overflow - flex_filled) + sum(count for pos, count in pos_counts.items() if pos not in core_positions)\n","req_bench = reqs.get(\"BENCH\", 6)\n","\n","active_cols = sum(1 for pos in core_positions if reqs.get(pos, 0) > 0) + (1 if req_flex > 0 else 0) + (1 if req_bench > 0 else 0)\n","prog_cols = st.columns(max(active_cols, 1))\n","col_index = 0\n","\n","for pos in core_positions:\n","    req_count = reqs.get(pos, 0)\n","    if req_count > 0:\n","        drafted_count = pos_counts.get(pos, 0)\n","        with prog_cols[col_index]:\n","            st.write(f\"**{pos}** ({min(drafted_count, req_count)}/{req_count})\")\n","            st.progress(min(drafted_count / req_count, 1.0))\n","        col_index += 1\n","\n","if req_flex > 0:\n","    with prog_cols[col_index]:\n","        st.write(f\"**FLEX** ({flex_filled}/{req_flex})\"); st.progress(min(flex_filled / req_flex, 1.0))\n","    col_index += 1\n","\n","if req_bench > 0:\n","    with prog_cols[col_index]:\n","        st.write(f\"**BENCH** ({min(bench_overflow, req_bench)}/{req_bench})\"); st.progress(min(bench_overflow / req_bench, 1.0) if req_bench > 0 else 1.0)\n","\n","st.markdown(\"---\")\n","st.header(\"🤖 AI Advisor\")\n","if st.button(\"Generate Gemini Prompt\"):\n","    generated_prompt = build_prompt(st.session_state.picks, my_team_id, my_team_name, current_pick, league_config, available_df)\n","    st.text_area(\"Copy this prompt into the Gemini Web App:\", value=generated_prompt, height=350)\n","\n","gemini_input = st.text_area(\"Paste Gemini's JSON Response below:\", height=150)\n","if st.button(\"Process AI Recommendation\"):\n","    if gemini_input:\n","        parsed_data = parse_gemini_response(gemini_input)\n","        if parsed_data:\n","            st.success(f\"### Recommended Pick: {parsed_data.get('pick')} ({parsed_data.get('position')})\")\n","            st.write(f\"**Reasoning:** {parsed_data.get('reasoning')}\")\n","        else: st.error(\"Could not parse valid JSON. Copy the ENTIRE prompt and response.\")\n","    else: st.warning(\"Please paste the response into the box first!\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"PeyYn2Q-t1aH","executionInfo":{"status":"ok","timestamp":1780879981924,"user_tz":300,"elapsed":60,"user":{"displayName":"Aaron Hurley","userId":"05835087564759951446"}},"outputId":"2577b72d-c576-447e-ba3d-0c44bc9b494a"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["Overwriting app.py\n"]}]},{"cell_type":"code","source":["!pip install pyngrok\n"],"metadata":{"id":"XdEb1Eueqq-O","executionInfo":{"status":"ok","timestamp":1780879708289,"user_tz":300,"elapsed":6926,"user":{"displayName":"Aaron Hurley","userId":"05835087564759951446"}},"outputId":"0d40525d-3956-4419-d70a-de903f18133d","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Collecting pyngrok\n","  Downloading pyngrok-8.1.2-py3-none-any.whl.metadata (8.6 kB)\n","Requirement already satisfied: PyYAML>=5.1 in /usr/local/lib/python3.12/dist-packages (from pyngrok) (6.0.3)\n","Downloading pyngrok-8.1.2-py3-none-any.whl (25 kB)\n","Installing collected packages: pyngrok\n","Successfully installed pyngrok-8.1.2\n"]}]},{"cell_type":"code","source":["import os\n","import time\n","from pyngrok import ngrok\n","\n","# 1. Kill any crashed or duplicate background processes\n","os.system(\"pkill -f streamlit\")\n","ngrok.kill()\n","\n","# 2. Set your auth token\n","# --- PASTE YOUR TOKEN BELOW ---\n","ngrok.set_auth_token(\"3EjRHHg7Bl3UVkyItrRhMpq25gV_437bzVnj7TeN6AFwZs3ak\")\n","\n","# 3. Start Streamlit (Forcing it to use 127.0.0.1 instead of localhost)\n","print(\"Starting Streamlit...\")\n","os.system(\"nohup python -m streamlit run app.py --server.port 8501 --server.address 127.0.0.1 &\")\n","\n","# Give it 5 seconds to fully boot up\n","time.sleep(5)\n","\n","# 4. Create the tunnel\n","public_url = ngrok.connect(8501)\n","\n","print(\"==================================================\")\n","print(f\"Success! Click this link to open your app: {public_url}\")\n","print(\"==================================================\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"6XNdLZJ7aW_T","executionInfo":{"status":"ok","timestamp":1780879757342,"user_tz":300,"elapsed":5856,"user":{"displayName":"Aaron Hurley","userId":"05835087564759951446"}},"outputId":"bfc0abde-2709-4c9a-f581-6fccb3f45e70"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Starting Streamlit...\n","==================================================\n","Success! Click this link to open your app: NgrokTunnel: \"https://battery-maternal-captivate.ngrok-free.dev\" -> \"http://localhost:8501\"\n","==================================================\n"]}]},{"cell_type":"code","source":["!cat nohup.out\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"b-ShthiQbGq5","executionInfo":{"status":"ok","timestamp":1780702147370,"user_tz":300,"elapsed":117,"user":{"displayName":"Aaron Hurley","userId":"05835087564759951446"}},"outputId":"df1a6d9a-fa30-4084-947e-894534f6a359"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["cat: nohup.out: No such file or directory\n"]}]},{"cell_type":"code","source":["# 1. Force install the missing modules!\n","!pip install -q streamlit pyngrok\n","\n","import os\n","import time\n","from pyngrok import ngrok\n","\n","# 2. Clean up any old attempts\n","os.system(\"pkill -f streamlit\")\n","ngrok.kill()\n","\n","# 3. Set your auth token\n","# --- PASTE YOUR TOKEN BELOW ---\n","ngrok.set_auth_token(\"3EjRHHg7Bl3UVkyItrRhMpq25gV_437bzVnj7TeN6AFwZs3ak\")\n","\n","# 4. Start Streamlit\n","print(\"Starting Streamlit...\")\n","os.system(\"nohup python -m streamlit run app.py --server.port 8501 --server.address 127.0.0.1 &\")\n","\n","# Give it 5 seconds to fully boot up\n","time.sleep(5)\n","\n","# 5. Create the tunnel\n","public_url = ngrok.connect(8501)\n","\n","print(\"==================================================\")\n","print(f\"Success! Click this link to open your app: {public_url}\")\n","print(\"==================================================\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"9ipyQW3nbh2t","executionInfo":{"status":"ok","timestamp":1780880026459,"user_tz":300,"elapsed":13732,"user":{"displayName":"Aaron Hurley","userId":"05835087564759951446"}},"outputId":"929de1cd-4c46-48d1-9014-e05b88f605cf"},"execution_count":9,"outputs":[{"output_type":"stream","name":"stdout","text":["\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m9.2/9.2 MB\u001b[0m \u001b[31m36.7 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m11.3/11.3 MB\u001b[0m \u001b[31m82.2 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[?25hStarting Streamlit...\n","==================================================\n","Success! Click this link to open your app: NgrokTunnel: \"https://battery-maternal-captivate.ngrok-free.dev\" -> \"http://localhost:8501\"\n","==================================================\n"]}]},{"cell_type":"code","source":["%%bash\n","mkdir -p .streamlit\n","cat <<EOF > .streamlit/config.toml\n","[theme]\n","primaryColor = \"#00FFFF\"\n","backgroundColor = \"#0E1117\"\n","secondaryBackgroundColor = \"#1E2530\"\n","textColor = \"#FFFFFF\"\n","font = \"sans serif\"\n","EOF\n"],"metadata":{"id":"4X-y7klmZy50"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["from google.colab import files\n","uploaded = files.upload()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":72},"id":"Q9wrySpEMKvs","executionInfo":{"status":"ok","timestamp":1780879859266,"user_tz":300,"elapsed":8457,"user":{"displayName":"Aaron Hurley","userId":"05835087564759951446"}},"outputId":"2f852b88-2b87-4608-dfb8-2da3a291c992"},"execution_count":7,"outputs":[{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.HTML object>"],"text/html":["\n","     <input type=\"file\" id=\"files-b4ea0d35-1995-4e14-b007-b1e313ce0bb0\" name=\"files[]\" multiple disabled\n","        style=\"border:none\" />\n","     <output id=\"result-b4ea0d35-1995-4e14-b007-b1e313ce0bb0\">\n","      Upload widget is only available when the cell has been executed in the\n","      current browser session. Please rerun this cell to enable.\n","      </output>\n","      <script>// Copyright 2017 Google LLC\n","//\n","// Licensed under the Apache License, Version 2.0 (the \"License\");\n","// you may not use this file except in compliance with the License.\n","// You may obtain a copy of the License at\n","//\n","//      http://www.apache.org/licenses/LICENSE-2.0\n","//\n","// Unless required by applicable law or agreed to in writing, software\n","// distributed under the License is distributed on an \"AS IS\" BASIS,\n","// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n","// See the License for the specific language governing permissions and\n","// limitations under the License.\n","\n","/**\n"," * @fileoverview Helpers for google.colab Python module.\n"," */\n","(function(scope) {\n","function span(text, styleAttributes = {}) {\n","  const element = document.createElement('span');\n","  element.textContent = text;\n","  for (const key of Object.keys(styleAttributes)) {\n","    element.style[key] = styleAttributes[key];\n","  }\n","  return element;\n","}\n","\n","// Max number of bytes which will be uploaded at a time.\n","const MAX_PAYLOAD_SIZE = 100 * 1024;\n","\n","function _uploadFiles(inputId, outputId) {\n","  const steps = uploadFilesStep(inputId, outputId);\n","  const outputElement = document.getElementById(outputId);\n","  // Cache steps on the outputElement to make it available for the next call\n","  // to uploadFilesContinue from Python.\n","  outputElement.steps = steps;\n","\n","  return _uploadFilesContinue(outputId);\n","}\n","\n","// This is roughly an async generator (not supported in the browser yet),\n","// where there are multiple asynchronous steps and the Python side is going\n","// to poll for completion of each step.\n","// This uses a Promise to block the python side on completion of each step,\n","// then passes the result of the previous step as the input to the next step.\n","function _uploadFilesContinue(outputId) {\n","  const outputElement = document.getElementById(outputId);\n","  const steps = outputElement.steps;\n","\n","  const next = steps.next(outputElement.lastPromiseValue);\n","  return Promise.resolve(next.value.promise).then((value) => {\n","    // Cache the last promise value to make it available to the next\n","    // step of the generator.\n","    outputElement.lastPromiseValue = value;\n","    return next.value.response;\n","  });\n","}\n","\n","/**\n"," * Generator function which is called between each async step of the upload\n"," * process.\n"," * @param {string} inputId Element ID of the input file picker element.\n"," * @param {string} outputId Element ID of the output display.\n"," * @return {!Iterable<!Object>} Iterable of next steps.\n"," */\n","function* uploadFilesStep(inputId, outputId) {\n","  const inputElement = document.getElementById(inputId);\n","  inputElement.disabled = false;\n","\n","  const outputElement = document.getElementById(outputId);\n","  outputElement.innerHTML = '';\n","\n","  const pickedPromise = new Promise((resolve) => {\n","    inputElement.addEventListener('change', (e) => {\n","      resolve(e.target.files);\n","    });\n","  });\n","\n","  const cancel = document.createElement('button');\n","  inputElement.parentElement.appendChild(cancel);\n","  cancel.textContent = 'Cancel upload';\n","  const cancelPromise = new Promise((resolve) => {\n","    cancel.onclick = () => {\n","      resolve(null);\n","    };\n","  });\n","\n","  // Wait for the user to pick the files.\n","  const files = yield {\n","    promise: Promise.race([pickedPromise, cancelPromise]),\n","    response: {\n","      action: 'starting',\n","    }\n","  };\n","\n","  cancel.remove();\n","\n","  // Disable the input element since further picks are not allowed.\n","  inputElement.disabled = true;\n","\n","  if (!files) {\n","    return {\n","      response: {\n","        action: 'complete',\n","      }\n","    };\n","  }\n","\n","  for (const file of files) {\n","    const li = document.createElement('li');\n","    li.append(span(file.name, {fontWeight: 'bold'}));\n","    li.append(span(\n","        `(${file.type || 'n/a'}) - ${file.size} bytes, ` +\n","        `last modified: ${\n","            file.lastModifiedDate ? file.lastModifiedDate.toLocaleDateString() :\n","                                    'n/a'} - `));\n","    const percent = span('0% done');\n","    li.appendChild(percent);\n","\n","    outputElement.appendChild(li);\n","\n","    const fileDataPromise = new Promise((resolve) => {\n","      const reader = new FileReader();\n","      reader.onload = (e) => {\n","        resolve(e.target.result);\n","      };\n","      reader.readAsArrayBuffer(file);\n","    });\n","    // Wait for the data to be ready.\n","    let fileData = yield {\n","      promise: fileDataPromise,\n","      response: {\n","        action: 'continue',\n","      }\n","    };\n","\n","    // Use a chunked sending to avoid message size limits. See b/62115660.\n","    let position = 0;\n","    do {\n","      const length = Math.min(fileData.byteLength - position, MAX_PAYLOAD_SIZE);\n","      const chunk = new Uint8Array(fileData, position, length);\n","      position += length;\n","\n","      const base64 = btoa(String.fromCharCode.apply(null, chunk));\n","      yield {\n","        response: {\n","          action: 'append',\n","          file: file.name,\n","          data: base64,\n","        },\n","      };\n","\n","      let percentDone = fileData.byteLength === 0 ?\n","          100 :\n","          Math.round((position / fileData.byteLength) * 100);\n","      percent.textContent = `${percentDone}% done`;\n","\n","    } while (position < fileData.byteLength);\n","  }\n","\n","  // All done.\n","  yield {\n","    response: {\n","      action: 'complete',\n","    }\n","  };\n","}\n","\n","scope.google = scope.google || {};\n","scope.google.colab = scope.google.colab || {};\n","scope.google.colab._files = {\n","  _uploadFiles,\n","  _uploadFilesContinue,\n","};\n","})(self);\n","</script> "]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Saving custom_player.csv.csv to custom_player.csv (1).csv\n"]}]}]}