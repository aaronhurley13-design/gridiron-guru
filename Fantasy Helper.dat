{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyNjk+DJ7A8AQvU2o6OeDzG6"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Mhx35yDZRBLi","executionInfo":{"status":"ok","timestamp":1780584509198,"user_tz":300,"elapsed":7,"user":{"displayName":"Aaron Hurley","userId":"05835087564759951446"}},"outputId":"3f4527b0-0daa-43c4-a229-136df4711431"},"outputs":[{"output_type":"stream","name":"stdout","text":["Patrick Mahomes threw for 38 TDs and 4839 yards\n","Mahomes\n","Hurts\n","['Mahomes', 'Burrow', 'Allen', 'Hurts', 'Lamar Jackson']\n","Justin Jefferson had 100 receptions\n","Jefferson scored 301.3 fantasy points (PPR)\n","Jefferson: 301.3 pts\n","Chase: 254.60000000000002 pts\n","Lamb: 252.2 pts\n"]}],"source":["# Variables and types\n","name = \"Patrick Mahomes\"\n","passing_tds = 38\n","passing_yards = 4839\n","print(f\"{name} threw for {passing_tds} TDs and {passing_yards} yards\")\n","\n","# List of players\n","qbs = [\"Mahomes\", \"Burrow\", \"Allen\", \"Hurts\"]\n","print(qbs[0]) # First QB\n","print(qbs[-1]) # Last QB\n","qbs.append(\"Lamar Jackson\")\n","print(qbs)\n","# A dict of player stats\n","player = {\n","    \"name\": \"Justin Jefferson\",\n","    \"position\": \"WR\",\n","    \"receiving_yards\": 1533,\n","    \"receiving_tds\": 8,\n","    \"receptions\": 100\n","}\n","print(f\"{player['name']} had {player['receptions']} receptions\")\n","\n","# A simple scoring function\n","def fantasy_points(yards, tds, receptions, ppr=1.0):\n","  return (yards * 0.1) + (tds * 6) + (receptions * ppr)\n","\n","jefferson_points = fantasy_points(1533, 8, 100, ppr=1.0)\n","print(f\"Jefferson scored {jefferson_points} fantasy points (PPR)\")\n","\n","# A list of dicts (this is what real data looks like)\n","wrs = [\n","    {\"name\": \"Jefferson\", \"yards\": 1533, \"tds\": 8, \"rec\": 100},\n","    {\"name\": \"Chase\",     \"yards\": 1216, \"tds\": 7, \"rec\": 91},\n","    {\"name\": \"Lamb\",      \"yards\": 1182, \"tds\": 6, \"rec\": 98},\n","]\n","\n","# Use loop to score all of them\n","for wr in wrs:\n","  pts = fantasy_points(wr['yards'], wr['tds'], wr['rec'], ppr=1.0)\n","  print(f\"{wr['name']}: {pts} pts\")\n","\n"]},{"cell_type":"code","source":["# 1. Install the brand new, active package\n","!pip install -q nflreadpy\n","\n","# 2. Import the libraries\n","import nflreadpy as nfl\n","import pandas as pd\n","\n","# 3. Pull the data (this loads weekly player logs)\n","weekly_stats = nfl.load_player_stats(seasons=[2024, 2025]).to_pandas()\n","\n","# 4. Filter for 2025 Wide Receivers\n","wrs_2025 = weekly_stats[(weekly_stats['season'] == 2025) & (weekly_stats['position'] == 'WR')]\n","\n","# 5. Group by player to sum up their weekly stats into season totals\n","season_totals = wrs_2025.groupby(['player_display_name', 'team']).agg({\n","    'receiving_yards': 'sum',\n","    'receiving_tds': 'sum',\n","    'receptions': 'sum'\n","}).reset_index()\n","\n","# 6. Sort and get the top 20\n","top_wrs = season_totals.sort_values('receiving_yards', ascending=False).head(20)\n","\n","# Display the final leader board\n","top_wrs\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":669},"id":"DeWeYePpCvaC","executionInfo":{"status":"ok","timestamp":1780694898398,"user_tz":300,"elapsed":8485,"user":{"displayName":"Aaron Hurley","userId":"05835087564759951446"}},"outputId":"a6db6652-9c01-4e86-9588-d2f6abf154e2"},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":["     player_display_name team  receiving_yards  receiving_tds  receptions\n","30   Christian McCaffrey   SF             1029              9         113\n","14        Bijan Robinson  ATL              820              4          79\n","68          Jahmyr Gibbs  DET              616              5          77\n","97      Kenneth Gainwell  PIT              512              3          77\n","43         De'Von Achane  MIA              488              4          67\n","125  Rhamondre Stevenson   NE              471              3          44\n","26           Chase Brown  CIN              437              5          69\n","119            RJ Harvey  DEN              424              5          56\n","98    Kenneth Walker III  SEA              386              0          40\n","82       Jonathan Taylor  IND              378              2          46\n","102       Kyren Williams   LA              351              5          44\n","18           Breece Hall  NYJ              350              1          36\n","8          Ashton Jeanty   LV              346              5          55\n","139       Travis Etienne  JAX              341              7          41\n","78         Jaylen Warren  PIT              337              2          41\n","35         D'Andre Swift  CHI              337              1          36\n","72            James Cook  BUF              320              2          37\n","126          Rico Dowdle  CAR              303              1          40\n","131       Saquon Barkley  PHI              298              2          40\n","153     Tyrone Tracy Jr.  NYG              288              2          36"],"text/html":["\n","  <div id=\"df-f5185799-99c3-41dd-864c-177401c396dd\" class=\"colab-df-container\">\n","    <div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=\"text-align: right;\">\n","      <th></th>\n","      <th>player_display_name</th>\n","      <th>team</th>\n","      <th>receiving_yards</th>\n","      <th>receiving_tds</th>\n","      <th>receptions</th>\n","    </tr>\n","  </thead>\n","  <tbody>\n","    <tr>\n","      <th>30</th>\n","      <td>Christian McCaffrey</td>\n","      <td>SF</td>\n","      <td>1029</td>\n","      <td>9</td>\n","      <td>113</td>\n","    </tr>\n","    <tr>\n","      <th>14</th>\n","      <td>Bijan Robinson</td>\n","      <td>ATL</td>\n","      <td>820</td>\n","      <td>4</td>\n","      <td>79</td>\n","    </tr>\n","    <tr>\n","      <th>68</th>\n","      <td>Jahmyr Gibbs</td>\n","      <td>DET</td>\n","      <td>616</td>\n","      <td>5</td>\n","      <td>77</td>\n","    </tr>\n","    <tr>\n","      <th>97</th>\n","      <td>Kenneth Gainwell</td>\n","      <td>PIT</td>\n","      <td>512</td>\n","      <td>3</td>\n","      <td>77</td>\n","    </tr>\n","    <tr>\n","      <th>43</th>\n","      <td>De'Von Achane</td>\n","      <td>MIA</td>\n","      <td>488</td>\n","      <td>4</td>\n","      <td>67</td>\n","    </tr>\n","    <tr>\n","      <th>125</th>\n","      <td>Rhamondre Stevenson</td>\n","      <td>NE</td>\n","      <td>471</td>\n","      <td>3</td>\n","      <td>44</td>\n","    </tr>\n","    <tr>\n","      <th>26</th>\n","      <td>Chase Brown</td>\n","      <td>CIN</td>\n","      <td>437</td>\n","      <td>5</td>\n","      <td>69</td>\n","    </tr>\n","    <tr>\n","      <th>119</th>\n","      <td>RJ Harvey</td>\n","      <td>DEN</td>\n","      <td>424</td>\n","      <td>5</td>\n","      <td>56</td>\n","    </tr>\n","    <tr>\n","      <th>98</th>\n","      <td>Kenneth Walker III</td>\n","      <td>SEA</td>\n","      <td>386</td>\n","      <td>0</td>\n","      <td>40</td>\n","    </tr>\n","    <tr>\n","      <th>82</th>\n","      <td>Jonathan Taylor</td>\n","      <td>IND</td>\n","      <td>378</td>\n","      <td>2</td>\n","      <td>46</td>\n","    </tr>\n","    <tr>\n","      <th>102</th>\n","      <td>Kyren Williams</td>\n","      <td>LA</td>\n","      <td>351</td>\n","      <td>5</td>\n","      <td>44</td>\n","    </tr>\n","    <tr>\n","      <th>18</th>\n","      <td>Breece Hall</td>\n","      <td>NYJ</td>\n","      <td>350</td>\n","      <td>1</td>\n","      <td>36</td>\n","    </tr>\n","    <tr>\n","      <th>8</th>\n","      <td>Ashton Jeanty</td>\n","      <td>LV</td>\n","      <td>346</td>\n","      <td>5</td>\n","      <td>55</td>\n","    </tr>\n","    <tr>\n","      <th>139</th>\n","      <td>Travis Etienne</td>\n","      <td>JAX</td>\n","      <td>341</td>\n","      <td>7</td>\n","      <td>41</td>\n","    </tr>\n","    <tr>\n","      <th>78</th>\n","      <td>Jaylen Warren</td>\n","      <td>PIT</td>\n","      <td>337</td>\n","      <td>2</td>\n","      <td>41</td>\n","    </tr>\n","    <tr>\n","      <th>35</th>\n","      <td>D'Andre Swift</td>\n","      <td>CHI</td>\n","      <td>337</td>\n","      <td>1</td>\n","      <td>36</td>\n","    </tr>\n","    <tr>\n","      <th>72</th>\n","      <td>James Cook</td>\n","      <td>BUF</td>\n","      <td>320</td>\n","      <td>2</td>\n","      <td>37</td>\n","    </tr>\n","    <tr>\n","      <th>126</th>\n","      <td>Rico Dowdle</td>\n","      <td>CAR</td>\n","      <td>303</td>\n","      <td>1</td>\n","      <td>40</td>\n","    </tr>\n","    <tr>\n","      <th>131</th>\n","      <td>Saquon Barkley</td>\n","      <td>PHI</td>\n","      <td>298</td>\n","      <td>2</td>\n","      <td>40</td>\n","    </tr>\n","    <tr>\n","      <th>153</th>\n","      <td>Tyrone Tracy Jr.</td>\n","      <td>NYG</td>\n","      <td>288</td>\n","      <td>2</td>\n","      <td>36</td>\n","    </tr>\n","  </tbody>\n","</table>\n","</div>\n","    <div class=\"colab-df-buttons\">\n","\n","  <div class=\"colab-df-container\">\n","    <button class=\"colab-df-convert\" onclick=\"convertToInteractive('df-f5185799-99c3-41dd-864c-177401c396dd')\"\n","            title=\"Convert this dataframe to an interactive table.\"\n","            style=\"display:none;\">\n","\n","  <svg xmlns=\"http://www.w3.org/2000/svg\" height=\"24px\" viewBox=\"0 -960 960 960\">\n","    <path d=\"M120-120v-720h720v720H120Zm60-500h600v-160H180v160Zm22